{
  "name": "pdf-invoicegenerator",
  "version": "1.0.0",
  "description": "SES PDF to Invoice Generator for M.D. Sinha & Sons",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^24.38.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14"
  },
  "build": {
    "appId": "com.mdsinha.invoice",
    "productName": "SES Invoice Generator",
    "files": [
      "**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
